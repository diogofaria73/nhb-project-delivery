NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nhb_status_report?schema=public"

JWT_SECRET="nhb-dev-secret-change-in-production"
JWT_EXPIRATION=28800

# CORS — comma-separated list of origins. Required when NODE_ENV=production.
CORS_ORIGIN="http://localhost:5173"

# ── Storage of submission attachments ─────────────────────────────────
# STORAGE_DRIVER=local|azure-blob (default: local)
STORAGE_DRIVER=local

# local driver: directory on disk (relative to apps/api)
STORAGE_LOCAL_PATH=./storage

# azure-blob driver: Azure Storage account credentials
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=status-reports
